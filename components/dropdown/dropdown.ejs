<%
  const {
    dropdownLabel,
    dropdownName,
    dropdownPlaceholder,
    dropdownSearchPlaceholder,
    dropdownEmptyText,
    dropdownHelper,
    dropdownMode,
    dropdownSearchable,
    dropdownShowLabel,
    dropdownStandalone,
    dropdownOptions,
    dropdownSelected,
    dropdownSummary
  } = loadConfig("./dropdown.config.js", { props });
%>

<% if (dropdownStandalone) { %>
  <link rel="stylesheet" href="<%= asset('./dropdown.css') %>" />
<% } %>

<div
  class="ui-field ui-dropdown"
  data-component="dropdown"
  data-name="<%= dropdownName %>"
  data-mode="<%= dropdownMode %>"
  data-placeholder="<%= dropdownPlaceholder %>"
  data-show-label="<%= String(dropdownShowLabel) %>"
  data-searchable="<%= String(dropdownSearchable) %>"
  data-empty-text="<%= dropdownEmptyText %>"
  data-has-options="<%= String(dropdownOptions.length > 0) %>"
>
  <% if (dropdownShowLabel && dropdownLabel) { %>
    <span class="ui-field__label"><%= dropdownLabel %></span>
  <% } %>

  <div class="ui-dropdown__frame">
    <script type="application/json" data-dropdown-options><%- JSON.stringify(dropdownOptions) %></script>
    <script type="application/json" data-dropdown-selected><%- JSON.stringify(dropdownSelected) %></script>

    <button type="button" class="ui-dropdown__trigger" aria-expanded="false" data-dropdown-trigger>
      <span class="ui-dropdown__summary" data-dropdown-summary><%= dropdownSummary %></span>
      <span class="ui-dropdown__chevron" aria-hidden="true">+</span>
    </button>

    <div class="ui-dropdown__panel" data-dropdown-panel hidden>
      <% if (dropdownSearchable && dropdownOptions.length > 0) { %>
        <!-- search -->
        <div class="ui-dropdown__search-wrap">
          <input
            type="search"
            class="ui-dropdown__search"
            placeholder="<%= dropdownSearchPlaceholder %>"
            data-dropdown-search
          />
        </div>
      <% } %>

      <% if (dropdownMode === "multiple") { %>
        <!-- multiple -->
        <div class="ui-dropdown__tags" data-dropdown-tags></div>
      <% } %>

      <div class="ui-dropdown__options" data-dropdown-options-list></div>
      <div class="ui-dropdown__inputs" data-dropdown-inputs></div>
    </div>
  </div>

  <% if (dropdownHelper) { %>
    <span class="ui-field__helper"><%= dropdownHelper %></span>
  <% } %>
</div>

<% if (dropdownStandalone) { %>
  <script type="module" src="<%= asset('./dropdown.js') %>"></script>
<% } %>
