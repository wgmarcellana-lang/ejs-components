<%
  const table = loadConfig("./data-table.config.js", { props });
%>

<% if (table.standalone) { %>
  <link rel="stylesheet" href="<%= asset('./data-table.css') %>" />
<% } %>

<div
  class="ui-data-table"
  data-component="data-table"
  id="<%= table.id %>"
  data-page-size="<%= table.pageSize %>"
  data-searchable="<%= String(table.searchable) %>"
  data-selectable="<%= String(table.selectable) %>"
  data-exportable="<%= String(table.exportable) %>"
  data-filterable="<%= String(table.filterable) %>"
  data-empty-text="<%= table.emptyText %>"
>

  <script type="application/json" data-table-columns><%- JSON.stringify(table.columns) %></script>
  <script type="application/json" data-table-rows><%- JSON.stringify(table.rows) %></script>
  <script type="application/json" data-table-page-size-options><%- JSON.stringify(table.pageSizeOptions) %></script>
  <script type="application/json" data-table-filters><%- JSON.stringify(table.filters) %></script>

  <!-- title -->
  <% if (table.title) { %>
    <div class="ui-data-table__header">
      <span class="ui-data-table__title"><%= table.title %></span>
    </div>
  <% } %>

  <!-- toolbar -->
  <div class="ui-data-table__toolbar">
    <div class="ui-data-table__toolbar-left">
      <% if (table.searchable) { %>
        <div class="ui-data-table__search-wrap">
          <span class="ui-data-table__search-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </span>
          <input
            class="ui-data-table__search"
            type="search"
            placeholder="<%= table.searchPlaceholder %>"
            data-table-search
            aria-label="Search table"
          />
        </div>
      <% } %>
    </div>

    <div class="ui-data-table__toolbar-right">
      <% if (table.filterable && table.filters.length) { %>
        <div class="ui-data-table__filter-wrap">
          <button class="ui-data-table__toolbar-btn" type="button" data-table-filter-btn aria-expanded="false" aria-label="Filter">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            <%= table.filterLabel %>
            <span class="ui-data-table__filter-badge" data-filter-badge hidden>0</span>
          </button>
          <div class="ui-data-table__filter-panel" data-table-filter-panel hidden>
            <div class="ui-data-table__filter-panel-header">
              <div>
                <h3 class="ui-data-table__filter-panel-title"><%= table.filterPanelTitle %></h3>
                <% if (table.filterPanelDescription) { %>
                  <p class="ui-data-table__filter-panel-copy"><%= table.filterPanelDescription %></p>
                <% } %>
              </div>
              <button class="ui-data-table__filter-close" type="button" data-table-filter-close aria-label="<%= table.filterCloseLabel %>">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
              </button>
            </div>

            <% table.filters.forEach(function(filter) { %>
              <div class="ui-data-table__filter-group">
                <div class="ui-data-table__filter-group-head">
                  <span class="ui-data-table__filter-group-label"><%= filter.label %></span>
                  <% if (filter.helper) { %>
                    <span class="ui-data-table__filter-group-helper"><%= filter.helper %></span>
                  <% } %>
                </div>

                <% if (filter.type === "date-range") { %>
                  <div
                    class="ui-data-table__filter-date-grid"
                    data-filter-type="date-range"
                    data-filter-key="<%= filter.key %>"
                  >
                    <label class="ui-data-table__filter-date-field">
                      <span class="ui-data-table__sr-only"><%= filter.fromLabel %></span>
                      <input
                        type="date"
                        class="ui-data-table__filter-date-input"
                        data-filter-date-from
                        data-filter-key="<%= filter.key %>"
                        placeholder="<%= filter.fromPlaceholder %>"
                      />
                    </label>
                    <label class="ui-data-table__filter-date-field">
                      <span class="ui-data-table__sr-only"><%= filter.toLabel %></span>
                      <input
                        type="date"
                        class="ui-data-table__filter-date-input"
                        data-filter-date-to
                        data-filter-key="<%= filter.key %>"
                        placeholder="<%= filter.toPlaceholder %>"
                      />
                    </label>
                  </div>
                <% } else { %>
                  <div
                    class="ui-data-table__filter-options<% if (filter.type === 'toggle-group') { %> ui-data-table__filter-options--pill<% } %>"
                    data-filter-type="<%= filter.type %>"
                    data-filter-key="<%= filter.key %>"
                    data-filter-multiple="<%= String(filter.allowMultiple) %>"
                  >
                    <% filter.options.forEach(function(opt) { %>
                      <% if (filter.type === "toggle-group") { %>
                        <button
                          class="ui-data-table__filter-pill is-selected"
                          type="button"
                          data-filter-pill
                          data-filter-key="<%= filter.key %>"
                          data-filter-value="<%= opt.value %>"
                          aria-pressed="true"
                        >
                          <% if (opt.color) { %>
                            <span class="ui-data-table__filter-pill-dot ui-data-table__filter-pill-dot--<%= opt.color %>" aria-hidden="true"></span>
                          <% } %>
                          <span><%= opt.label %></span>
                        </button>
                      <% } else { %>
                        <label class="ui-data-table__filter-option">
                          <input
                            type="checkbox"
                            class="ui-data-table__filter-check"
                            data-filter-key="<%= filter.key %>"
                            data-filter-value="<%= opt.value %>"
                            checked
                          />
                          <span><%= opt.label %></span>
                        </label>
                      <% } %>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            <% }); %>
            <div class="ui-data-table__filter-actions">
              <button class="ui-data-table__filter-reset" type="button" data-table-filter-clear><%= table.filterResetLabel %></button>
              <div class="ui-data-table__filter-actions-right">
                <button class="ui-data-table__filter-cancel" type="button" data-table-filter-cancel><%= table.filterCancelLabel %></button>
                <button class="ui-data-table__filter-apply" type="button" data-table-filter-apply><%= table.filterApplyLabel %></button>
              </div>
            </div>
          </div>
        </div>
      <% } %>
      <% if (table.exportable) { %>
        <button class="ui-data-table__toolbar-btn" type="button" data-table-export aria-label="Export">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <%= table.exportLabel %>
        </button>
      <% } %>
    </div>
  </div>

  <!-- table -->
  <div class="ui-data-table__scroll">
    <table class="ui-data-table__table" role="grid"<% if (table.caption) { %> aria-label="<%= table.caption %>"<% } %>>
      <thead class="ui-data-table__thead">
        <tr>
          <% if (table.selectable) { %>
            <th class="ui-data-table__th ui-data-table__th--check" scope="col">
              <input type="checkbox" class="ui-data-table__check" data-table-select-all aria-label="Select all rows" />
            </th>
          <% } %>
          <% table.columns.forEach(function(col) { %>
            <th
              class="ui-data-table__th<% if (col.sortable && col.type !== 'action') { %> ui-data-table__th--sortable<% } %>"
              scope="col"
              data-col-key="<%= col.key %>"
              <% if (col.sortable && col.type !== 'action') { %>
                data-table-sort="<%= col.key %>"
                aria-sort="none"
                tabindex="0"
                role="columnheader"
              <% } %>
            >
              <span class="ui-data-table__th-inner">
                <%= col.label %>
                <% if (col.sortable && col.type !== 'action') { %>
                  <span class="ui-data-table__sort-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor">
                      <path d="M8 3l3.5 4h-7L8 3zm0 10L4.5 9h7L8 13z"/>
                    </svg>
                  </span>
                <% } %>
              </span>
            </th>
          <% }); %>
        </tr>
      </thead>
      <tbody class="ui-data-table__tbody" data-table-body>
      </tbody>
    </table>
  </div>

  <!-- footer -->
  <div class="ui-data-table__footer">
    <div class="ui-data-table__footer-left">
      <span class="ui-data-table__showing-label">Showing:</span>
      <div class="ui-data-table__page-size-wrap">
        <select class="ui-data-table__page-size-select" data-table-page-size aria-label="Rows per page">
          <% table.pageSizeOptions.forEach(function(opt) { %>
            <option value="<%= opt %>" <%= opt === table.pageSize ? "selected" : "" %>><%= opt %></option>
          <% }); %>
        </select>
      </div>
      <span class="ui-data-table__info" data-table-info aria-live="polite"></span>
    </div>

    <nav class="ui-data-table__pagination" aria-label="Table pagination">
      <button class="ui-data-table__page-btn" type="button" data-table-prev aria-label="Previous page">Prev</button>
      <div class="ui-data-table__pages" data-table-pages></div>
      <button class="ui-data-table__page-btn" type="button" data-table-next aria-label="Next page">Next</button>
    </nav>
  </div>

</div>

<% if (table.standalone) { %>
  <script type="module" src="<%= asset('./data-table.js') %>"></script>
<% } %>
