<%
  const {
    calendarLabel,
    calendarName,
    calendarSingleLabel,
    calendarStartLabel,
    calendarEndLabel,
    calendarStartName,
    calendarEndName,
    calendarStartValue,
    calendarEndValue,
    calendarHelper,
    calendarMode,
    calendarShowLabel,
    calendarShowInputLabels,
    calendarAllowModeSwitch,
    calendarRequired,
    calendarStandalone,
    isRange
  } = loadConfig("./calendar.config.js", { props });
%>

<% if (calendarStandalone) { %>
  <link rel="stylesheet" href="<%= asset('./calendar.css') %>" />
<% } %>

<div
  class="ui-calendar"
  data-component="calendar"
  data-mode="<%= calendarMode %>"
  data-name="<%= calendarName %>"
  data-start-name="<%= calendarStartName %>"
  data-end-name="<%= calendarEndName %>"
  data-single-label="<%= calendarSingleLabel %>"
  data-start-label="<%= calendarStartLabel %>"
  data-end-label="<%= calendarEndLabel %>"
  data-required="<%= String(calendarRequired) %>"
>
  <div class="ui-calendar__frame">
    <% if (calendarShowLabel && calendarLabel) { %>
      <span class="ui-field__label"><%= calendarLabel %></span>
    <% } %>

    <% if (calendarAllowModeSwitch) { %>
      <!-- switch between range and single -->
      <div class="ui-calendar__toggle" role="radiogroup" aria-label="<%= calendarLabel || "Calendar" %> mode">
        <label class="ui-calendar__toggle-option <%= !isRange ? "is-active" : "" %>">
          <input type="radio" name="<%= `${calendarName}-mode` %>" value="single" data-calendar-mode <%= !isRange ? "checked" : "" %> />
          <span>Date</span>
        </label>
        <label class="ui-calendar__toggle-option <%= isRange ? "is-active" : "" %>">
          <input type="radio" name="<%= `${calendarName}-mode` %>" value="range" data-calendar-mode <%= isRange ? "checked" : "" %> />
          <span>Date Range</span>
        </label>
      </div>
    <% } %>

    <div class="ui-calendar__inputs" data-calendar-inputs>
      <label class="ui-calendar__slot <%= isRange ? "ui-calendar__slot--hidden" : "" %>" data-calendar-single-wrap>
        <% if (calendarShowInputLabels && calendarSingleLabel) { %>
          <span class="ui-calendar__slot-label"><%= calendarSingleLabel %></span>
        <% } %>
        <div class="ui-calendar__display-field">
          <button
            class="ui-calendar__control ui-calendar__display"
            type="button"
            data-calendar-single-trigger
            aria-label="<%= calendarSingleLabel || "Date" %>"
          >
            <span class="ui-calendar__display-text" data-calendar-single-display>MM/DD/YYYY</span>
            <span class="ui-calendar__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
              </svg>
            </span>
          </button>
          <input
            type="hidden"
            data-calendar-single-input
            name="<%= isRange ? "" : calendarName %>"
            value="<%= calendarStartValue %>"
            <%= isRange ? "disabled" : "" %>
            <%= calendarRequired ? "required" : "" %>
          />
        </div>
      </label>

      <div class="ui-calendar__range <%= isRange ? "" : "ui-calendar__range--hidden" %>" data-calendar-range-wrap>
        <div class="ui-calendar__range-fields">
          <label class="ui-calendar__slot">
            <% if (calendarShowInputLabels && calendarStartLabel) { %>
              <span class="ui-calendar__slot-label"><%= calendarStartLabel %></span>
            <% } %>
            <div class="ui-calendar__display-field">
              <button
                class="ui-calendar__control ui-calendar__display"
                type="button"
                data-calendar-start-trigger
                aria-label="<%= calendarStartLabel || "Start Date" %>"
              >
                <span class="ui-calendar__display-text" data-calendar-start-display>MM/DD/YYYY</span>
                <span class="ui-calendar__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
                  </svg>
                </span>
              </button>
              <input
                type="hidden"
                data-calendar-start-input
                name="<%= calendarStartName %>"
                value="<%= calendarStartValue %>"
                <%= !isRange ? "disabled" : "" %>
              />
            </div>
          </label>

          <label class="ui-calendar__slot">
            <% if (calendarShowInputLabels && calendarEndLabel) { %>
              <span class="ui-calendar__slot-label"><%= calendarEndLabel %></span>
            <% } %>
            <div class="ui-calendar__display-field">
              <button
                class="ui-calendar__control ui-calendar__display"
                type="button"
                data-calendar-end-trigger
                aria-label="<%= calendarEndLabel || "End Date" %>"
              >
                <span class="ui-calendar__display-text" data-calendar-end-display>MM/DD/YYYY</span>
                <span class="ui-calendar__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
                  </svg>
                </span>
              </button>
              <input
                type="hidden"
                data-calendar-end-input
                name="<%= calendarEndName %>"
                value="<%= calendarEndValue %>"
                <%= !isRange ? "disabled" : "" %>
              />
            </div>
          </label>
        </div>
      </div>

      <div class="ui-calendar__panel" data-calendar-panel hidden>
        <div class="ui-calendar__panel-header">
          <button class="ui-calendar__nav" type="button" data-calendar-prev aria-label="Previous month">&lt;</button>
          <div class="ui-calendar__title-group">
            <div class="ui-calendar__picker-rail" aria-label="Calendar month and year">
              <label class="ui-calendar__picker ui-calendar__picker--month">
                <select data-calendar-month aria-label="Select month"></select>
              </label>
              <label class="ui-calendar__picker ui-calendar__picker--year">
                <select data-calendar-year aria-label="Select year"></select>
              </label>
            </div>
          </div>
          <button class="ui-calendar__nav" type="button" data-calendar-next aria-label="Next month">&gt;</button>
        </div>

        <div class="ui-calendar__weekdays" aria-hidden="true">
          <span>Sun</span>
          <span>Mon</span>
          <span>Tue</span>
          <span>Wed</span>
          <span>Thu</span>
          <span>Fri</span>
          <span>Sat</span>
        </div>

        <div class="ui-calendar__grid" data-calendar-grid></div>
      </div>
    </div>
  </div>

  <% if (calendarHelper) { %>
    <span class="ui-field__helper"><%= calendarHelper %></span>
  <% } %>
</div>

<% if (calendarStandalone) { %>
  <script type="module" src="<%= asset('./calendar.js') %>"></script>
<% } %>
