<%
  const calendar = loadConfig("./calendar.config.js", { props });
%>

<% if (calendar.standalone) { %>
  <link rel="stylesheet" href="<%= asset('./calendar.css') %>" />
<% } %>

<div
  class="ui-calendar"
  data-component="calendar"
  data-mode="<%= calendar.mode %>"
  data-name="<%= calendar.name %>"
  data-start-name="<%= calendar.startName %>"
  data-end-name="<%= calendar.endName %>"
  data-single-label="<%= calendar.singleLabel %>"
  data-start-label="<%= calendar.startLabel %>"
  data-end-label="<%= calendar.endLabel %>"
  data-required="<%= String(calendar.required) %>"
>
  <div class="ui-calendar__frame">
    <% if (calendar.showLabel && calendar.label) { %>
      <span class="ui-field__label"><%= calendar.label %></span>
    <% } %>

    <% if (calendar.allowModeSwitch) { %>
      <div class="ui-calendar__toggle" role="radiogroup" aria-label="<%= calendar.label || "Calendar" %> mode">
        <label class="ui-calendar__toggle-option <%= !calendar.isRange ? "is-active" : "" %>">
          <input type="radio" name="<%= `${calendar.name}-mode` %>" value="single" data-calendar-mode <%= !calendar.isRange ? "checked" : "" %> />
          <span>Date</span>
        </label>
        <label class="ui-calendar__toggle-option <%= calendar.isRange ? "is-active" : "" %>">
          <input type="radio" name="<%= `${calendar.name}-mode` %>" value="range" data-calendar-mode <%= calendar.isRange ? "checked" : "" %> />
          <span>Date Range</span>
        </label>
      </div>
    <% } %>

    <div class="ui-calendar__inputs" data-calendar-inputs>
      <label class="ui-calendar__slot <%= calendar.isRange ? "ui-calendar__slot--hidden" : "" %>" data-calendar-single-wrap>
        <% if (calendar.showInputLabels && calendar.singleLabel) { %>
          <span class="ui-calendar__slot-label"><%= calendar.singleLabel %></span>
        <% } %>
        <div class="ui-calendar__display-field">
          <button
            class="ui-calendar__control ui-calendar__display"
            type="button"
            data-calendar-single-trigger
            aria-label="<%= calendar.singleLabel || "Date" %>"
          >
            <span class="ui-calendar__display-text" data-calendar-single-display>MM/DD/YYYY</span>
            <span class="ui-calendar__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
              </svg>
            </span>
          </button>
          <input
            type="hidden"
            data-calendar-single-input
            name="<%= calendar.isRange ? "" : calendar.name %>"
            value="<%= calendar.startValue %>"
            <%= calendar.isRange ? "disabled" : "" %>
            <%= calendar.required ? "required" : "" %>
          />
        </div>
      </label>

      <div class="ui-calendar__range <%= calendar.isRange ? "" : "ui-calendar__range--hidden" %>" data-calendar-range-wrap>
        <div class="ui-calendar__range-fields">
          <label class="ui-calendar__slot">
            <% if (calendar.showInputLabels && calendar.startLabel) { %>
              <span class="ui-calendar__slot-label"><%= calendar.startLabel %></span>
            <% } %>
            <div class="ui-calendar__display-field">
              <button
                class="ui-calendar__control ui-calendar__display"
                type="button"
                data-calendar-start-trigger
                aria-label="<%= calendar.startLabel || "Start Date" %>"
              >
                <span class="ui-calendar__display-text" data-calendar-start-display>MM/DD/YYYY</span>
                <span class="ui-calendar__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
                  </svg>
                </span>
              </button>
              <input
                type="hidden"
                data-calendar-start-input
                name="<%= calendar.startName %>"
                value="<%= calendar.startValue %>"
                <%= !calendar.isRange ? "disabled" : "" %>
              />
            </div>
          </label>

          <label class="ui-calendar__slot">
            <% if (calendar.showInputLabels && calendar.endLabel) { %>
              <span class="ui-calendar__slot-label"><%= calendar.endLabel %></span>
            <% } %>
            <div class="ui-calendar__display-field">
              <button
                class="ui-calendar__control ui-calendar__display"
                type="button"
                data-calendar-end-trigger
                aria-label="<%= calendar.endLabel || "End Date" %>"
              >
                <span class="ui-calendar__display-text" data-calendar-end-display>MM/DD/YYYY</span>
                <span class="ui-calendar__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm13 8H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8ZM6 6a1 1 0 0 0-1 1v1h15V7a1 1 0 0 0-1-1H6Z"></path>
                  </svg>
                </span>
              </button>
              <input
                type="hidden"
                data-calendar-end-input
                name="<%= calendar.endName %>"
                value="<%= calendar.endValue %>"
                <%= !calendar.isRange ? "disabled" : "" %>
              />
            </div>
          </label>
        </div>
      </div>

      <div class="ui-calendar__panel" data-calendar-panel hidden>
        <div class="ui-calendar__panel-header">
          <button class="ui-calendar__nav" type="button" data-calendar-prev aria-label="Previous month">&lt;</button>
          <div class="ui-calendar__title-group">
            <div class="ui-calendar__picker-rail" aria-label="Calendar month and year">
              <label class="ui-calendar__picker ui-calendar__picker--month">
                <select data-calendar-month aria-label="Select month"></select>
              </label>
              <label class="ui-calendar__picker ui-calendar__picker--year">
                <select data-calendar-year aria-label="Select year"></select>
              </label>
            </div>
          </div>
          <button class="ui-calendar__nav" type="button" data-calendar-next aria-label="Next month">&gt;</button>
        </div>

        <div class="ui-calendar__weekdays" aria-hidden="true">
          <span>Sun</span>
          <span>Mon</span>
          <span>Tue</span>
          <span>Wed</span>
          <span>Thu</span>
          <span>Fri</span>
          <span>Sat</span>
        </div>

        <div class="ui-calendar__grid" data-calendar-grid></div>
      </div>
    </div>
  </div>

  <% if (calendar.helper) { %>
    <span class="ui-field__helper"><%= calendar.helper %></span>
  <% } %>
</div>

<% if (calendar.standalone) { %>
  <script type="module" src="<%= asset('./calendar.js') %>"></script>
<% } %>
