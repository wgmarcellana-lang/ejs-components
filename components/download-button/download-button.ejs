<%
  const button = loadConfig("./download-button.config.js", { props });
%>

<% if (button.standalone) { %>
  <link rel="stylesheet" href="<%= asset('./download-button.css') %>" />
<% } %>

<a
  class="ui-download-button ui-download-button--<%= button.variant %> ui-download-button--<%= button.size %>"
  data-component="download-button"
  data-href="<%= button.href %>"
  data-file-name="<%= button.fileName %>"
  data-target-preview="<%= button.targetPreview %>"
  data-fallback-href="<%= button.fallbackHref %>"
  data-fallback-file-name="<%= button.fallbackFileName %>"
  data-disabled="<%= String(button.disabled) %>"
  href="<%= button.disabled ? '#' : (button.href || button.fallbackHref || '#') %>"
  <%= button.fileName || button.fallbackFileName ? `download="${button.fileName || button.fallbackFileName}"` : "download" %>
  aria-disabled="<%= String(button.disabled) %>"
>
  <span class="ui-download-button__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3v11"/>
      <path d="M7 10l5 5 5-5"/>
      <path d="M5 21h14"/>
    </svg>
  </span>
  <span><%= button.label %></span>
</a>

<% if (button.standalone) { %>
  <script type="module" src="<%= asset('./download-button.js') %>"></script>
<% } %>
