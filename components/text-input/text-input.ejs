<%
  const input = loadConfig("./text-input.config.js", { props });
  const inputId = input.id || `${input.name}-input`;
  const helperId = input.helper ? `${inputId}-helper` : "";
%>

<% if (input.standalone) { %>
  <link rel="stylesheet" href="<%= asset('./text-input.css') %>" />
<% } %>

<label
  class="ui-field ui-text-input"
  data-component="text-input"
  data-show-label="<%= String(input.showLabel) %>"
  data-has-toggle="<%= String(input.type === "password") %>"
>
  <% if (input.showLabel && input.label) { %>
    <span class="ui-field__label"><%= input.label %></span>
  <% } %>

  <span class="ui-text-input__control-wrap">
    <input
      class="ui-text-input__control"
      type="<%= input.type %>"
      id="<%= inputId %>"
      name="<%= input.name %>"
      placeholder="<%= input.placeholder %>"
      value="<%= input.value %>"
      <%- input.autocomplete ? `autocomplete="${input.autocomplete}"` : "" %>
      <%= input.required ? "required" : "" %>
      <% if (helperId) { %>aria-describedby="<%= helperId %>"<% } %>
    />

    <% if (input.type === "password") { %>
      <button
        class="ui-text-input__toggle"
        type="button"
        data-password-toggle
        aria-pressed="false"
        aria-label="<%= input.toggleLabel %>"
      >
        Show
      </button>
    <% } %>
  </span>

  <% if (input.helper) { %>
    <span class="ui-field__helper" id="<%= helperId %>"><%= input.helper %></span>
  <% } %>
</label>

<% if (input.standalone) { %>
  <script type="module" src="<%= asset('./text-input.js') %>"></script>
<% } %>
