<%
  const {
    inputLabel,
    inputName,
    inputPlaceholder,
    inputHelper,
    inputType,
    inputValue,
    inputId,
    inputAutocomplete,
    inputToggleLabel,
    inputRequired,
    inputShowLabel,
    inputStandalone
  } = loadConfig("./text-input.config.js", { props });
%>

<% if (inputStandalone) { %>
  <link rel="stylesheet" href="<%= asset('./text-input.css') %>" />
<% } %>

<label
  class="ui-field ui-text-input"
  data-component="text-input"
  data-show-label="<%= String(inputShowLabel) %>"
  data-has-toggle="<%= String(inputType === "password") %>"
>
  <% if (inputShowLabel && inputLabel) { %>
    <span class="ui-field__label"><%= inputLabel %></span>
  <% } %>

  <span class="ui-text-input__control-wrap">
    <input
      class="ui-text-input__control"
      type="<%= inputType %>"
      <%- inputId ? `id="${inputId}"` : "" %>
      name="<%= inputName %>"
      placeholder="<%= inputPlaceholder %>"
      value="<%= inputValue %>"
      <%- inputAutocomplete ? `autocomplete="${inputAutocomplete}"` : "" %>
      <%= inputRequired ? "required" : "" %>
    />

    <% if (inputType === "password") { %>
      <button
        class="ui-text-input__toggle"
        type="button"
        data-password-toggle
        aria-pressed="false"
        aria-label="<%= inputToggleLabel %>"
      >
        Show
      </button>
    <% } %>
  </span>

  <% if (inputHelper) { %>
    <span class="ui-field__helper"><%= inputHelper %></span>
  <% } %>
</label>

<% if (inputStandalone) { %>
  <script type="module" src="<%= asset('./text-input.js') %>"></script>
<% } %>
