<%
  // Resolve props up front so the markup below stays readable.
  const inputProps = props && typeof props === "object" ? props : {};
  const textOr = (value, fallback, requireValue = false) =>
    typeof value === "string" && (!requireValue || value) ? value : fallback;

  const inputLabel = textOr(inputProps.label, "Text Input");
  const inputName = textOr(inputProps.name, "textInput", true);
  const inputPlaceholder = textOr(inputProps.placeholder, "");
  const inputHelper = textOr(inputProps.helper, "");
  const inputType = textOr(inputProps.type, "text", true);
  const inputValue = textOr(inputProps.value, "");
  const inputRequired = inputProps.required === true;
  const inputShowLabel = inputProps.showLabel !== false;
  const inputStandalone = inputProps.standalone === true;
%>

<% if (inputStandalone) { %>
  <link rel="stylesheet" href="/components/text-input.css" />
<% } %>

<label
  class="ui-field ui-text-input"
  data-component="text-input"
  data-show-label="<%= String(inputShowLabel) %>"
>
  <% if (inputShowLabel) { %>
    <span class="ui-field__label"><%= inputLabel %></span>
  <% } %>

  <input
    class="ui-text-input__control"
    type="<%= inputType %>"
    name="<%= inputName %>"
    placeholder="<%= inputPlaceholder %>"
    value="<%= inputValue %>"
    <%= inputRequired ? "required" : "" %>
  />

  <% if (inputHelper) { %>
    <span class="ui-field__helper"><%= inputHelper %></span>
  <% } %>
</label>

<% if (inputStandalone) { %>
  <script type="module">
    import { initTextInputs } from "/components/text-input.js";
    initTextInputs();
  </script>
<% } %>
