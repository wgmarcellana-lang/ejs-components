<%
  // Collect the modal setup here so the visible HTML stays simple.
  const modalProps = props && typeof props === "object" ? props : {};
  const textOr = (value, fallback, requireValue = false) =>
    typeof value === "string" && (!requireValue || value) ? value : fallback;

  const modalId = textOr(modalProps.id, "ui-modal", true);
  const modalTitle = textOr(modalProps.title, "Modal");
  const modalMode = ["message", "confirmation", "custom"].includes(modalProps.mode)
    ? modalProps.mode
    : "message";
  const modalConfig = {
    mode: modalMode,
    title: modalTitle,
    message: textOr(modalProps.message, ""),
    bodyHtml: typeof modalProps.bodyHtml === "string" ? modalProps.bodyHtml : "",
    closeText: textOr(modalProps.closeText, "Close", true),
    cancelText: textOr(modalProps.cancelText, "Cancel", true),
    confirmText: textOr(modalProps.confirmText, "OK", true),
    confirmVariant: textOr(modalProps.confirmVariant, "primary", true),
    buttons: Array.isArray(modalProps.buttons) ? modalProps.buttons : []
  };
%>

<div
  id="<%= modalId %>"
  class="ui-modal"
  data-component="modal"
  aria-hidden="true"
>
  <!-- message, confirmation, or custom -->
  <script type="application/json" data-modal-config><%- JSON.stringify(modalConfig) %></script>
  <div class="ui-modal__backdrop" data-modal-close tabindex="-1"></div>

  <div
    class="ui-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="<%= modalId %>-title"
    tabindex="-1"
  >
    <div class="ui-modal__header">
      <h2 id="<%= modalId %>-title" class="ui-modal__title" data-modal-title>
        <%= modalTitle %>
      </h2>

      <!-- close -->
      <button
        type="button"
        class="ui-modal__close"
        aria-label="Close modal"
        data-modal-close
      >
        &times;
      </button>
    </div>

    <!--body -->
    <div class="ui-modal__body" data-modal-body></div>

    <!-- footer -->
    <div class="ui-modal__footer" data-modal-footer></div>
  </div>
</div>
