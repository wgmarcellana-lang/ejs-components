<%
  const modal = loadConfig("./modal.config.js", { props });
%>

<% if (modal.standalone) { %>
  <link rel="stylesheet" href="<%= asset('./modal.css') %>" />
<% } %>

<div
  id="<%= modal.id %>"
  class="ui-modal"
  data-component="modal"
  aria-hidden="true"
>
  <script type="application/json" data-modal-config><%- JSON.stringify(modal.config) %></script>
  <div class="ui-modal__backdrop" data-modal-close tabindex="-1"></div>

  <div
    class="ui-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="<%= modal.id %>-title"
    tabindex="-1"
  >
    <div class="ui-modal__header">
      <h2 id="<%= modal.id %>-title" class="ui-modal__title" data-modal-title>
        <%= modal.title %>
      </h2>

      <button
        type="button"
        class="ui-modal__close"
        aria-label="Close modal"
        data-modal-close
      >
        &times;
      </button>
    </div>

    <div class="ui-modal__body" data-modal-body></div>
    <div class="ui-modal__footer" data-modal-footer></div>
  </div>
</div>

<% if (modal.standalone) { %>
  <script type="module" src="<%= asset('./modal.js') %>"></script>
<% } %>
