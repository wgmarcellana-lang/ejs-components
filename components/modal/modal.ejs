<%
  const { modalId, modalTitle, modalStandalone, modalConfig } = loadConfig(
    "./modal.config.js",
    { props }
  );
%>

<% if (modalStandalone) { %>
  <link rel="stylesheet" href="<%= asset('./modal.css') %>" />
<% } %>

<div
  id="<%= modalId %>"
  class="ui-modal"
  data-component="modal"
  aria-hidden="true"
>
  <!-- message, confirmation, or custom -->
<script type="application/json" data-modal-config><%- JSON.stringify(modalConfig) %></script>
  <div class="ui-modal__backdrop" data-modal-close tabindex="-1"></div>

  <div
    class="ui-modal__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="<%= modalId %>-title"
    tabindex="-1"
  >
    <div class="ui-modal__header">
      <h2 id="<%= modalId %>-title" class="ui-modal__title" data-modal-title>
        <%= modalTitle %>
      </h2>

      <!-- close -->
      <button
        type="button"
        class="ui-modal__close"
        aria-label="Close modal"
        data-modal-close
      >
        &times;
      </button>
    </div>

    <div class="ui-modal__body" data-modal-body></div>
    <div class="ui-modal__footer" data-modal-footer></div>
  </div>
</div>

<% if (modalStandalone) { %>
  <script type="module" src="<%= asset('./modal.js') %>"></script>
<% } %>
