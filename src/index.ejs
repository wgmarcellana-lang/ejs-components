<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EJS Frontend V2</title>
    <link rel="stylesheet" href="/src/styles.css" />
  </head>

  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <main class="page-shell" id="main-content">
      <section class="demo-card">
        <div class="demo-card__header">
          <div>
            <h1>EJS Frontend Demo</h1>
          </div>
        </div>

        <form class="component-form" data-demo-form>
          <div class="form-feedback" data-form-feedback aria-live="assertive" hidden></div>
          <div class="component-grid">

            <!-- input -->
            <%- include("../components/text-input/text-input.ejs", {
              props: {
                label: "Text Input Component",
                name: "textTest",
                placeholder: "Enter text",
                type: "text",
                required: true,
              }
            }) %>

            <!-- dropdown -->
            <%- include("../components/dropdown/dropdown.ejs", {
              props: {
                label: "Dropdown Component",
                name: "dropdownTest",
                placeholder: "Select options",
                searchPlaceholder: "Search options",
                emptyText: "No options found.",
                mode: "multiple",
                searchable: true,
                options: [
                  { label: "Option 1", value: "option1" },
                  { label: "Option 2", value: "option2" },
                  { label: "Option 3", value: "option3" },
                  { label: "Option 4", value: "option4" }
                ]
              }
            }) %>

            <!-- calendar -->
            <%- include("../components/calendar/calendar.ejs", {
              props: {
                label: "Calendar Component",
                name: "testDate",
                singleLabel: "Date",
                startLabel: "Start Date",
                endLabel: "End Date",
                startName: "testStart",
                endName: "testEnd",
                mode: "single", 
                allowModeSwitch: true,
              }
            }) %>
          </div>

          <!-- data table -->
          <%- include("../components/data-table/data-table.ejs", {
            props: {
              id: "demo-table",
              title: "Data Table Component",
              searchable: true,
              selectable: true,
              exportable: true,
              // filter configs
              filterable: true,
              filterPresentation: "modal", // or popup like yung dati
              filterLabel: "Filter",
              filterPanelTitle: "Filter Records",
              filterPanelDescription: "Adjust the criteria below to refine the results.",
              filterCloseLabel: "Close filter panel",
              filterResetLabel: "Reset All",
              filterCancelLabel: "Cancel",
              filterApplyLabel: "Apply Filters",
              filters: [
                // bday filter
                {
                  key: "birthday",
                  type: "date-range",
                  label: "Birthday",
                  helper: "Filter celebrities by birthday range."
                },
                // gender filter
                {
                  key: "gender",
                  type: "toggle-group",
                  label: "Gender",
                  allowMultiple: true,
                  options: [
                    { label: "Female", value: "Female", color: "red"  },
                    { label: "Male",   value: "Male",   color: "blue" }
                  ]
                },
                // status filter
                {
                  key: "status",
                  type: "toggle-group",
                  label: "Filter by Status",
                  allowMultiple: true,
                  options: [
                    { label: "Booked",     value: "Booked",     color: "green"  },
                    { label: "Trending",   value: "Trending",   color: "blue"   },
                    { label: "On Hold",    value: "On Hold",    color: "yellow" },
                    { label: "Cancelled",  value: "Cancelled",  color: "red"    },
                    { label: "Rumored",    value: "Rumored",    color: "gray"   }
                  ]
                }
              ],
              pageSize: 5,
              pageSizeOptions: [5, 10, 25],
              searchPlaceholder: "Search records…",
              columns: [
                { key: "application",  label: "Application Number",  sortable: true,  type: "text"   },
                { key: "name",         label: "Name",                sortable: true,  type: "text"   },
                { key: "gender",       label: "Gender",              sortable: true,  type: "text"   },
                { key: "birthday",     label: "Birthday",            sortable: true,  type: "text"   },
                {
                  key: "status",
                  label: "Status",
                  sortable: true,
                  type: "badge",
                  badgeMap: {
                    "Booked":    { label: "Booked",    color: "green"  },
                    "Trending":  { label: "Trending",  color: "blue"   },
                    "On Hold":   { label: "On Hold",   color: "yellow" },
                    "Cancelled": { label: "Cancelled", color: "red"    },
                    "Rumored":   { label: "Rumored",   color: "gray"   }
                  }
                },
                {
                  key: "action",
                  label: "Action",
                  sortable: false,
                  type: "action",
                  action: { label: "View", event: "datatable:action" }
                }
              ],
              rows: [
                { application: "GENZ-2026-0001", name: "Zendaya",            gender: "Female", birthday: "September 01, 1996", status: "Booked"    },
                { application: "GENZ-2026-0002", name: "Tom Holland",        gender: "Male",   birthday: "June 01, 1996",      status: "Trending"  },
                { application: "GENZ-2026-0003", name: "Olivia Rodrigo",     gender: "Female", birthday: "February 20, 2003",  status: "Booked"    },
                { application: "GENZ-2026-0004", name: "Jenna Ortega",       gender: "Female", birthday: "September 27, 2002", status: "Trending"  },
                { application: "GENZ-2026-0005", name: "Billie Eilish",      gender: "Female", birthday: "December 18, 2001",  status: "On Hold"   },
                { application: "GENZ-2026-0006", name: "Timothee Chalamet",  gender: "Male",   birthday: "December 27, 1995",  status: "Booked"    },
                { application: "GENZ-2026-0007", name: "Millie Bobby Brown", gender: "Female", birthday: "February 19, 2004",  status: "Rumored"   },
                { application: "GENZ-2026-0008", name: "JoJo Siwa",          gender: "Female", birthday: "May 19, 2003",       status: "Cancelled" },
                { application: "GENZ-2026-0009", name: "Lil Nas X",          gender: "Male",   birthday: "April 09, 1999",     status: "Trending"  },
                { application: "GENZ-2026-0010", name: "Noah Schnapp",       gender: "Male",   birthday: "October 03, 2004",   status: "On Hold"   },
                { application: "GENZ-2026-0011", name: "Emma Chamberlain",   gender: "Female", birthday: "May 22, 2001",       status: "Rumored"   },
                { application: "GENZ-2026-0012", name: "Charli D'Amelio",    gender: "Female", birthday: "May 01, 2004",       status: "Trending"  },
                { application: "GENZ-2026-0013", name: "Iann Dior",          gender: "Male",   birthday: "March 25, 1999",     status: "Cancelled" },
                { application: "GENZ-2026-0014", name: "Dove Cameron",       gender: "Female", birthday: "January 15, 1996",   status: "Booked"    },
                { application: "GENZ-2026-0015", name: "Loren Gray",         gender: "Female", birthday: "April 19, 2002",     status: "On Hold"   }
              ]
            }
          }) %>

          <!-- media -->
          <section class="media-demo">
            <article class="media-demo__card">
              <div class="media-demo__header">
                <h2>Image Preview Component</h2>
              </div>

              <div class="media-demo__panel media-demo__panel--preview">
                <!-- image preview -->
                <%- include("../components/image-preview/image-preview.ejs", {
                  props: {
                    id: "profile-preview",
                    label: "Image Preview Component",
                    size: "medium",
                    shape: "circle",
                    alt: "Selected profile image preview",
                    enlargeOnClick: true
                  }
                }) %>
              </div>
            </article>

            <article class="media-demo__card">
              <div class="media-demo__header">
                <h2>File Upload Component</h2>
              </div>

              <div class="media-demo__panel">
                <!-- file upload -->
                <%- include("../components/file-upload/file-upload.ejs", {
                  props: {
                    id: "profile-upload",
                    name: "profileUpload",
                    label: "Upload Image",
                    accept: "image/*,.webp,.png,.jpg,.jpeg",
                    helper: "Drag a file here.",
                    buttonLabel: "Choose image",
                    dropLabel: "Drop image here",
                    previewTarget: "#profile-preview",
                    maxFileSize: 5242880
                  }
                }) %>
              </div>
            </article>

            <article class="media-demo__card">
              <div class="media-demo__header">
                <h2>Download Button Component</h2>
              </div>

              <div class="media-demo__actions">
                <%- include("../components/button/button.ejs", {
                  props: {
                    label: "Download Current Image",
                    variant: "secondary",
                    size: "md",
                    action: "download",
                    icon: "download",
                    href: "/src/assets/no-user.webp",
                    download: {
                      fileName: "no-user.webp",
                      targetPreview: "#profile-preview",
                      fallbackHref: "/src/assets/no-user.webp",
                      fallbackFileName: "no-user.webp"
                    }
                  }
                }) %>
              </div>
            </article>
          </section>

          <!-- for testing only -->
          <section class="form-output" aria-live="polite">
            <div class="form-output__header">
              <h2>Submission Response</h2>
            </div>
            <pre class="form-output__code" data-demo-output>No submission yet.</pre>
          </section>

          <!-- buttons -->
          <div class="form-actions">
            <%- include("../components/button/button.ejs", {
              props: {
                label: "Reset",
                variant: "secondary",
                type: "button",
                action: "reset-form"
              }
            }) %>
            <%- include("../components/button/button.ejs", {
              props: {
                label: "Modal Testing",
                variant: "secondary",
                type: "button",
                action: "open-modal-testing"
              }
            }) %>
            <%- include("../components/button/button.ejs", {
              props: {
                label: "Submit",
                variant: "primary",
                type: "submit"
              }
            }) %>
          </div>
          
        </form>
      </section>

    </main>

    <!-- modal -->
    <%- include("../components/modal/modal.ejs", {
      props: {
        id: "generic-modal",
        title: "Test Confirmation Modal",
        mode: "custom",
        message: "Are you sure?",
        closeText: "Close",
        cancelText: "Cancel",
        confirmText: "OK",
        confirmVariant: "primary",
        bodyHtml: include("../components/text-input/text-input.ejs", {
          props: {
            label: "Username",
            id: "modal-username",
            name: "modalUsername",
            placeholder: "Enter username",
            type: "text"
          }
        }) + include("../components/text-input/text-input.ejs", {
          props: {
            label: "Password",
            id: "modal-password",
            name: "modalPassword",
            placeholder: "Enter password",
            type: "password",
            autocomplete: "current-password"
          }
        }),
        buttons: [
          { label: "Cancel", variant: "secondary", close: true },
          { label: "Save", variant: "primary", close: true }
        ]
      }
    }) %>

    <script type="module" src="/src/main.js"></script>
  </body>
</html>
